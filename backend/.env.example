# Application Mode
ENVIRONMENT=development  # Set to "production" in production to activate strict key checks

# Application Configuration
LOG_LEVEL=INFO

# Database Configuration
# SQLite local default (auto-created):
DATABASE_URL=sqlite:///./beauty_pim.db
# PostgreSQL Production Example:
# DATABASE_URL=postgresql://pim_user:pim_pass@localhost:5432/beauty_pim

# Security Configuration
# WARNING: Production mode will crash if SECRET_KEY is default or fewer than 32 characters.
SECRET_KEY=change_this_to_a_secure_random_32_character_string_for_production

# Account Bootstrap Options
ALLOW_INITIAL_ADMIN_BOOTSTRAP=true
INITIAL_ADMIN_BOOTSTRAP_TOKEN=your_secure_bootstrap_token_here

# Rate Limits (optional overrides)
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_UPLOADS=10/minute
RATE_LIMIT_PROCESS=5/minute

# Webhooks (SSRF safety)
# Comma-separated list of allowed domains (e.g. ceartas.io)
# WEBHOOK_ALLOWED_DOMAINS=ceartas.io,example.com

# Gemini AI Enrichment Configuration
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional organization-specific policy; the guarded prompt still requires evidence and unknowns.
# ENRICHMENT_CUSTOM_INSTRUCTIONS=Extract only supported beauty product facts.

# Job queue controls
BATCH_SIZE=5
MAX_CONCURRENCY=3
MAX_JOB_COST_LIMIT=50.0
