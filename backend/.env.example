# Application Configuration
LOG_LEVEL=INFO

# Database Configuration
# SQLite local default (auto-created)
DATABASE_URL=sqlite:///./beauty_pim.db
# PostgreSQL Production Example:
# DATABASE_URL=postgresql://pim_user:pim_pass@localhost:5432/beauty_pim

# Security Configuration
SECRET_KEY=replace_this_with_a_secure_random_string_for_production_use

# Gemini AI Enrichment Configuration
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Job queue controls
BATCH_SIZE=5
MAX_CONCURRENCY=3
MAX_JOB_COST_LIMIT=50.0
